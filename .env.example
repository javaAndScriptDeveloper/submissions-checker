# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/submissions_checker
# For local development outside Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/submissions_checker

# GitHub Integration
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY_PATH=/app/secrets/github-app-private-key.pem
GITHUB_API_BASE_URL=https://api.github.com

# AI Provider Settings
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# Scheduler Settings
SCHEDULER_ENABLED=true

# Outbox Settings
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL=10
OUTBOX_MAX_RETRIES=5
OUTBOX_RETRY_BACKOFF_SECONDS=60

# API Settings
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
